{
  "name": "ai-memory-vault",
  "version": "0.1.0",
  "description": "AI-maintained development memory vault for Claude Code, OpenClaw, Codex and other coding agents.",
  "type": "module",
  "bin": {
    "ai-vault": "./scripts/ai-vault.js"
  },
  "scripts": {
    "scan": "node scripts/ai-vault.js scan",
    "claim": "node scripts/ai-vault.js claim",
    "export": "node scripts/ai-vault.js export",
    "summarize": "node scripts/ai-vault.js summarize",
    "context": "node scripts/ai-vault.js context",
    "validate": "node scripts/ai-vault.js validate",
    "test": "node --test tests/*.test.js",
    "status": "node scripts/ai-vault.js status",
    "sync": "node scripts/ai-vault.js sync",
    "list-assets": "node scripts/ai-vault.js list-assets",
    "asset": "node scripts/ai-vault.js asset",
    "impact": "node scripts/ai-vault.js impact",
    "map": "node scripts/ai-vault.js map",
    "promote": "node scripts/ai-vault.js promote",
    "index": "node scripts/ai-vault.js index",
    "search": "node scripts/ai-vault.js search",
